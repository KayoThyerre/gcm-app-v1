generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(uuid())
  name                     String
  email                    String    @unique
  password                 String
  phone                    String?
  avatarUrl                String?
  role                     Role      @default(USER)
  status                   Status    @default(PENDING)
  emailVerified            Boolean   @default(false)
  verificationToken        String?
  verificationTokenExpires DateTime?
  lastVerificationSentAt   DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model News {
  id        String   @id @default(uuid())
  title     String
  slug      String
  content   String
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Approach {
  id          String    @id @default(uuid())
  name        String
  cpf         String?
  rg          String?
  birthDate   DateTime?
  motherName  String?
  notes       String?
  isConvicted Boolean   @default(false)
  photoUrl    String?
  createdById String
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ScaleMonth {
  id            String              @id @default(uuid())
  month         Int
  year          Int
  days          ScaleDay[]
  teamConfigs   ScaleTeamConfig[]
  cellOverrides ScaleCellOverride[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model ScaleDay {
  id           String            @id @default(uuid())
  scaleMonthId String
  date         DateTime
  shiftType    ShiftType
  notes        String?
  scaleMonth   ScaleMonth        @relation(fields: [scaleMonthId], references: [id], onDelete: Cascade)
  assignments  ScaleAssignment[]
}

model ScaleAssignment {
  id          String    @id @default(uuid())
  scaleDayId  String
  name        String
  roleInShift ScaleRole
  startTime   String
  endTime     String
  scaleDay    ScaleDay  @relation(fields: [scaleDayId], references: [id], onDelete: Cascade)
}

model ScaleTeamConfig {
  id                String            @id @default(uuid())
  scaleMonthId      String
  teamName          String
  initialCycle      InitialCycle
  supervisorName    String
  radioOperatorName String
  scaleMonth        ScaleMonth        @relation(fields: [scaleMonthId], references: [id], onDelete: Cascade)
  members           ScaleTeamMember[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model ScaleTeamMember {
  id           String          @id @default(uuid())
  teamConfigId String
  name         String
  teamConfig   ScaleTeamConfig @relation(fields: [teamConfigId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
}

model ScaleCellOverride {
  id           String         @id @default(uuid())
  scaleMonthId String
  teamName     String
  personName   String
  day          Int
  value        ScaleCellValue
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  scaleMonth   ScaleMonth     @relation(fields: [scaleMonthId], references: [id], onDelete: Cascade)

  @@unique([scaleMonthId, teamName, personName, day])
}

enum InitialCycle {
  DAY
  NIGHT_START
  NIGHT_END
  OFF
}

enum ScaleCellValue {
  DAY
  NIGHT_START
  NIGHT_END
  NIGHT_FULL
  OFF
  MEDICAL_LEAVE
  BANK_HOURS
  VACATION
}

enum ShiftType {
  DAY
  NIGHT
}

enum ScaleRole {
  SUPERVISOR
  RADIO_OPERATOR
  PATROL
}

enum Role {
  ADMIN
  USER
  SUPERVISOR
  DEV
}

enum Status {
  ACTIVE
  PENDING
  INACTIVE
}